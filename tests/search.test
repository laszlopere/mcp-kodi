#!/bin/sh
# Functional test for the `search` tool.
#
# Drives the real mcp-kodi binary over its MCP stdio transport against a live
# Kodi, exercising `search` across all three media types (music / tv-show /
# movie) and a spread of argument combinations (count, limit, offset paging,
# album/season/track narrowing) plus the error and no-match paths.
#
# Library-agnostic: it discovers a real song, episode and movie from the target
# Kodi and asserts against those values, so it passes against any *populated*
# library rather than assuming particular titles.
#
# Preconditions (else the test SKIPs, automake exit 77):
#   - jq and curl on PATH
#   - the mcp-kodi binary built
#   - a reachable Kodi that answers JSONRPC.Ping with "pong"
#
# Target Kodi defaults to the local test instance; override via the environment:
#   KODI_HOST=127.0.0.1:8080  KODI_AUTH=user:pass  KODI_SCHEME=http
#
# Exit: 0 all assertions passed · 1 a failure · 77 skipped.

set -u

KODI_HOST=${KODI_HOST:-127.0.0.1:8080}
KODI_AUTH=${KODI_AUTH:-kodi:kodi}
KODI_SCHEME=${KODI_SCHEME:-http}
export KODI_HOST KODI_AUTH KODI_SCHEME

SKIP=77

skip () { echo "SKIP: $*"; exit $SKIP; }

# ---- dependencies ---------------------------------------------------------

command -v jq   >/dev/null 2>&1 || skip "jq not found"
command -v curl >/dev/null 2>&1 || skip "curl not found"

# Locate the mcp-kodi binary: the automake build tree first ($top_builddir is
# exported by `make check`), then fallbacks for running the script by hand.
find_binary () {
  for c in \
    "${top_builddir:-}/src/mcp-kodi" \
    "$(dirname "$0")/../src/mcp-kodi" \
    "./src/mcp-kodi" \
    "src/mcp-kodi"
  do
    if [ -n "$c" ] && [ -x "$c" ]; then printf '%s\n' "$c"; return 0; fi
  done
  return 1
}
MCP=$(find_binary) || skip "mcp-kodi binary not built"

# ---- talking to Kodi directly (for discovery + the liveness gate) ---------

kodi_rpc () { # method params-json  ->  raw JSON-RPC response
  curl -s -m 20 -u "$KODI_AUTH" -H 'Content-Type: application/json' \
    --data "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"$1\",\"params\":$2}" \
    "$KODI_SCHEME://$KODI_HOST/jsonrpc"
}

pong=$(kodi_rpc JSONRPC.Ping '{}' | jq -r '.result // empty' 2>/dev/null)
[ "$pong" = "pong" ] || skip "Kodi not reachable at $KODI_SCHEME://$KODI_HOST"

# ---- talking to the server under test (MCP over stdio) --------------------

# Feed `initialize` + one `tools/call`, echo back the tool result object for
# request id 2 (`{ content:[{type,text}], isError }`). The server reads
# newline-delimited JSON and exits on EOF, so one invocation per call keeps
# every assertion isolated.
mcp_tool () { # name arguments-json  ->  tool result object
  printf '%s\n%s\n' \
    '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2025-06-18","capabilities":{}}}' \
    "{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"tools/call\",\"params\":{\"name\":\"$1\",\"arguments\":$2}}" \
    | "$MCP" 2>/dev/null \
    | jq -c 'select(.id==2) | .result'
}

search   () { mcp_tool search "$1"; }          # arguments-json -> result object
res_err  () { printf '%s' "$1" | jq -r '.isError'; }            # "true" | "false"
res_body () { printf '%s' "$1" | jq -c '.content[0].text | fromjson'; }  # tool payload
jargs    () { jq -cn "$@"; }                   # build an arguments object safely
g        () { printf '%s' "$1" | jq -r "$2"; } # body, filter -> scalar
j        () { printf '%s' "$1" | jq    "$2"; } # body, filter -> json/bool
jx       () { b=$1; shift; printf '%s' "$b" | jq "$@"; } # body, jq-args... (--argjson)

# ---- assertions -----------------------------------------------------------

PASS=0
FAIL=0
ok () { PASS=$((PASS + 1)); printf '  ok   %s\n' "$1"; }
no () { FAIL=$((FAIL + 1)); printf '  FAIL %s\n' "$1"; shift; [ $# -gt 0 ] && printf '       %s\n' "$*"; return 0; }

eq () { # desc expected actual
  if [ "x$2" = "x$3" ]; then ok "$1"; else no "$1" "expected [$2] got [$3]"; fi
}
is_true () { # desc jq-bool-string
  if [ "x$2" = "xtrue" ]; then ok "$1"; else no "$1" "condition was [$2]"; fi
}

# Invariants every successful search result must hold (the response shape).
check_invariants () { # body type expected-offset label
  b=$1; t=$2; off=$3; p=$4
  eq   "$p — type is \"$t\""        "$t"  "$(g "$b" '.type')"
  eq   "$p — offset echoed"         "$off" "$(g "$b" '.offset')"
  eq   "$p — returned == rows len"  "$(g "$b" '.returned')" "$(g "$b" '.rows|length')"
  is_true "$p — total >= returned"  "$(j "$b" '.total >= .returned')"
  is_true "$p — offset >= 0"        "$(j "$b" '.offset >= 0')"
  # truncated is exactly "more rows lie beyond this page".
  eq   "$p — truncated flag consistent" \
       "$(j "$b" '(.offset + .returned) < .total')" "$(g "$b" '.truncated')"
}

echo "search functional test — Kodi at $KODI_SCHEME://$KODI_HOST, binary $MCP"

# ===========================================================================
# 1. Reachability + noop (the prerequisite the task calls out explicitly).
# ===========================================================================
echo "-- reachability / noop"
noop=$(mcp_tool noop '{}')
eq "noop is not an error" false "$(res_err "$noop")"
nbody=$(res_body "$noop")
is_true "noop reports a player state field" "$(j "$nbody" 'has("state")')"
echo "   (player state: $(g "$nbody" '.state'))"

# ===========================================================================
# 2. Discover real library entities to assert against.
# ===========================================================================
song=$(kodi_rpc AudioLibrary.GetSongs \
         '{"properties":["artist","album","track"],"limits":{"start":0,"end":1}}' \
        | jq -c '.result.songs[0] // empty')
episode=$(kodi_rpc VideoLibrary.GetEpisodes \
         '{"properties":["showtitle","season","episode"],"limits":{"start":0,"end":1}}' \
        | jq -c '.result.episodes[0] // empty')
movie=$(kodi_rpc VideoLibrary.GetMovies \
         '{"limits":{"start":0,"end":1}}' \
        | jq -r '.result.movies[0].label // empty')

artist=""; album=""; track=""
if [ -n "$song" ]; then
  artist=$(g "$song" '.artist[0] // ""')
  album=$(g  "$song" '.album // ""')
  track=$(g  "$song" '.track // 0')
fi
show=""; season=""; epnum=""
if [ -n "$episode" ]; then
  show=$(g   "$episode" '.showtitle // ""')
  season=$(g "$episode" '.season // 0')
  epnum=$(g  "$episode" '.episode // 0')
fi

# ===========================================================================
# 3. Music — artist resolve, count, paging, album + track narrowing.
# ===========================================================================
echo "-- music"
if [ -n "$artist" ]; then
  echo "   (artist: $artist · album: $album · track: $track)"

  b=$(res_body "$(search "$(jargs --arg a "$artist" '{type:"music",artist:$a,count:true}')")")
  check_invariants "$b" music 0 "music/count"
  eq      "music/count returns zero rows"   0    "$(g "$b" '.returned')"
  is_true "music resolves an artistid"      "$(j "$b" '(.resolved.artistid // 0) > 0')"
  total=$(g "$b" '.total')

  b=$(res_body "$(search "$(jargs --arg a "$artist" '{type:"music",artist:$a,limit:3}')")")
  check_invariants "$b" music 0 "music/limit"
  is_true "music/limit caps rows at 3"      "$(j "$b" '.returned <= 3')"
  if [ "$(j "$b" '.returned > 0')" = true ]; then
    is_true "music row carries a file path"  "$(j "$b" '.rows[0] | has("file") and (.file|length>0)')"
    is_true "music row carries a songid"     "$(j "$b" '(.rows[0].songid // 0) > 0')"
  fi
  first_page_id=$(g "$b" '.rows[0].songid // 0')

  # Second page is offset-disjoint when the discography spans it.
  b=$(res_body "$(search "$(jargs --arg a "$artist" '{type:"music",artist:$a,limit:3,offset:3}')")")
  check_invariants "$b" music 3 "music/offset"
  if [ "$total" -gt 3 ] 2>/dev/null && [ "$(j "$b" '.returned > 0')" = true ]; then
    eq    "music page 2 differs from page 1" false \
          "$(jx "$b" --argjson p "$first_page_id" 'any(.rows[]; .songid == $p)')"
  fi

  # Album (title) narrows within the artist.
  if [ -n "$album" ]; then
    b=$(res_body "$(search "$(jargs --arg a "$artist" --arg al "$album" \
                              '{type:"music",artist:$a,title:$al,limit:50}')")")
    check_invariants "$b" music 0 "music/album"
    is_true "music/album finds the album"   "$(j "$b" '.total >= 1')"
  fi

  # Track number narrows to that position.
  if [ -n "$album" ] && [ "$track" -gt 0 ] 2>/dev/null; then
    b=$(res_body "$(search "$(jargs --arg a "$artist" --arg al "$album" --argjson n "$track" \
                              '{type:"music",artist:$a,title:$al,number:$n}')")")
    check_invariants "$b" music 0 "music/track"
    if [ "$(j "$b" '.returned > 0')" = true ]; then
      eq  "music/track returns only track $track" true \
          "$(jx "$b" --argjson n "$track" 'all(.rows[]; .track == $n)')"
    fi
  fi
else
  echo "   (no songs in library — music assertions skipped)"
fi

# ===========================================================================
# 4. TV — show resolve, episode list, SxxExx narrowing.
# ===========================================================================
echo "-- tv-show"
if [ -n "$show" ]; then
  echo "   (show: $show · S${season}E${epnum})"

  b=$(res_body "$(search "$(jargs --arg s "$show" '{type:"tv-show",title:$s,count:true}')")")
  check_invariants "$b" tv-show 0 "tv/count"
  eq      "tv/count returns zero rows"  0  "$(g "$b" '.returned')"
  is_true "tv resolves a tvshowid"      "$(j "$b" '(.resolved.tvshowid // 0) > 0')"

  b=$(res_body "$(search "$(jargs --arg s "$show" '{type:"tv-show",title:$s,limit:5}')")")
  check_invariants "$b" tv-show 0 "tv/limit"
  is_true "tv/limit caps rows at 5"     "$(j "$b" '.returned <= 5')"
  if [ "$(j "$b" '.returned > 0')" = true ]; then
    is_true "tv row carries a file path"  "$(j "$b" '.rows[0] | has("file") and (.file|length>0)')"
    is_true "tv row carries an episodeid" "$(j "$b" '(.rows[0].episodeid // 0) > 0')"
  fi

  # The discovered season/episode must exist for its own show.
  b=$(res_body "$(search "$(jargs --arg s "$show" --argjson se "$season" --argjson n "$epnum" \
                            '{type:"tv-show",title:$s,season:$se,number:$n}')")")
  check_invariants "$b" tv-show 0 "tv/SxxExx"
  is_true "tv/SxxExx finds the episode" "$(j "$b" '.total >= 1')"
  if [ "$(j "$b" '.returned > 0')" = true ]; then
    eq "tv/SxxExx matches the season"  true "$(jx "$b" --argjson se "$season" 'all(.rows[]; .season  == $se)')"
    eq "tv/SxxExx matches the episode" true "$(jx "$b" --argjson n  "$epnum"  'all(.rows[]; .episode == $n)')"
  fi
else
  echo "   (no episodes in library — tv assertions skipped)"
fi

# ===========================================================================
# 5. Movie — count + title match.
# ===========================================================================
echo "-- movie"
if [ -n "$movie" ]; then
  echo "   (movie: $movie)"

  b=$(res_body "$(search '{"type":"movie","count":true}')")
  check_invariants "$b" movie 0 "movie/count"
  eq      "movie/count returns zero rows" 0 "$(g "$b" '.returned')"
  is_true "movie library is non-empty"    "$(j "$b" '.total >= 1')"

  b=$(res_body "$(search '{"type":"movie","limit":1}')")
  check_invariants "$b" movie 0 "movie/limit"
  is_true "movie/limit caps rows at 1"    "$(j "$b" '.returned <= 1')"
  if [ "$(j "$b" '.returned > 0')" = true ]; then
    is_true "movie row carries a file path" "$(j "$b" '.rows[0] | has("file") and (.file|length>0)')"
    is_true "movie row carries a movieid"   "$(j "$b" '(.rows[0].movieid // 0) > 0')"
  fi

  b=$(res_body "$(search "$(jargs --arg t "$movie" '{type:"movie",title:$t,limit:5}')")")
  check_invariants "$b" movie 0 "movie/title"
  is_true "movie/title finds the movie"   "$(j "$b" '.total >= 1')"
else
  echo "   (no movies in library — movie assertions skipped)"
fi

# ===========================================================================
# 6. Error + edge paths (no discovery needed).
#    A bad request is a clean tool error (isError:true), never a crash; a
#    no-match is a normal empty result.
# ===========================================================================
echo "-- errors / edges"

b=$(search '{}')
eq "missing type -> tool error" true "$(res_err "$b")"
case "$(g "$(res_body "$b")" '.error')" in
  *type*) ok "missing-type error names \"type\"";;
  *)      no "missing-type error names \"type\"";;
esac

b=$(search '{"type":"banana"}')
eq "unknown type -> tool error" true "$(res_err "$b")"

b=$(search '{"type":"music"}')
eq "music without artist -> tool error" true "$(res_err "$b")"
case "$(g "$(res_body "$b")" '.error')" in
  *artist*) ok "music error names \"artist\"";;
  *)        no "music error names \"artist\"";;
esac

b=$(search '{"type":"tv-show"}')
eq "tv-show without title -> tool error" true "$(res_err "$b")"
case "$(g "$(res_body "$b")" '.error')" in
  *title*) ok "tv error names \"title\"";;
  *)       no "tv error names \"title\"";;
esac

# A genuine no-match is success with an empty result set, not an error.
b=$(search "$(jargs '{type:"music",artist:"zzqq-no-such-artist-zzqq"}')")
eq "no-match music is not an error" false "$(res_err "$b")"
nb=$(res_body "$b")
eq "no-match total is 0"     0 "$(g "$nb" '.total')"
eq "no-match returned is 0"  0 "$(g "$nb" '.returned')"
eq "no-match rows are empty" 0 "$(g "$nb" '.rows|length')"

# ===========================================================================
# 7. Library report — exercise `search` to enumerate and print real content.
#    This both stresses the listing path (multiple rows, multiple containers)
#    and gives a human-readable peek at what is in the target library.
# ===========================================================================
echo "-- library report"

# Songs: a sample of the discovered artist's tracks (track · title · album).
echo "   songs:"
if [ -n "$artist" ]; then
  b=$(res_body "$(search "$(jargs --arg a "$artist" '{type:"music",artist:$a,limit:10}')")")
  is_true "song listing returns rows" "$(j "$b" '.returned >= 1')"
  printf '     %s — %s of %s tracks\n' "$artist" "$(g "$b" '.returned')" "$(g "$b" '.total')"
  printf '%s' "$b" | jq -r '
    .rows[] | "       #\(.track // 0)  \(.title)  ·  [\(.album // "—")]  ·  \((.duration // 0))s"'
else
  echo "     (no songs in library)"
fi

# Movies: title (year), runtime in minutes, and the playable file.
echo "   movies:"
b=$(res_body "$(search '{"type":"movie","limit":10}')")
if [ "$(j "$b" '.returned >= 1')" = true ]; then
  is_true "movie listing returns rows" "$(j "$b" '.returned >= 1')"
  printf '     %s of %s movies\n' "$(g "$b" '.returned')" "$(g "$b" '.total')"
  printf '%s' "$b" | jq -r '
    .rows[] | "       \(.title) (\(.year // "—"))  ·  \(((.runtime // 0) / 60) | floor)m  ·  \(.file)"'
else
  echo "     (no movies in library)"
fi

# TV shows: for a handful of shows, episode count + a sample episode. Drives
# `search` once per show (count) and once for the sample — the multi-container
# listing path the single-show tests above do not cover.
echo "   tv shows:"
shows=$(kodi_rpc VideoLibrary.GetTVShows '{"limits":{"start":0,"end":5}}' \
        | jq -r '.result.tvshows[]?.label // empty')
if [ -n "$shows" ]; then
  printf '%s\n' "$shows" | while IFS= read -r s; do
    [ -n "$s" ] || continue
    cnt=$(res_body "$(search "$(jargs --arg s "$s" '{type:"tv-show",title:$s,count:true}')")")
    eps=$(g "$cnt" '.total')
    smp=$(res_body "$(search "$(jargs --arg s "$s" '{type:"tv-show",title:$s,limit:1}')")")
    first=$(printf '%s' "$smp" | jq -r '
      (.rows[0] // empty) | "S\(.season)E\(.episode) “\(.title)”"')
    [ -n "$first" ] || first="(no episodes)"
    printf '       %-32s %5s eps   e.g. %s\n' "$s" "$eps" "$first"
  done
  # The loop runs in a subshell (pipe), so assert show coverage out here.
  is_true "tv report found shows to list" "$(printf '%s' "$shows" | jq -Rrs '(split("\n") | map(select(length>0)) | length) >= 1 | tostring')"
else
  echo "     (no tv shows in library)"
fi

# ---- tally ----------------------------------------------------------------
echo "------------------------------------------------------------"
printf 'search functional test: %d passed, %d failed\n' "$PASS" "$FAIL"
[ "$FAIL" -eq 0 ] || exit 1
exit 0
