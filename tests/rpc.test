#!/bin/sh
# Functional test for the `rpc` escape hatch — TODO.md §11.6.6 / §7.7.
#
# Drives the real mcp-kodi binary over its MCP stdio transport against a live
# Kodi. `rpc` is the passthrough: it sends any JSON-RPC method and returns
# Kodi's raw `result` unshaped — but only for an instance that has opted in via
# the hand-edit-only `allow_rpc` config flag (§7.7). This test exercises both
# sides of that gate:
#   - an opted-in instance: ping/echo come back verbatim, a Kodi error becomes a
#     tool error, and bad arguments are clean tool errors;
#   - an instance that has NOT opted in: `rpc` is refused before any Kodi call,
#     with an error that points at `allow_rpc`.
# It also checks that the gate cannot be flipped through the `instances` tool —
# the whole point of the hand-edit-only design.
#
# Because `allow_rpc` is deliberately not settable via environment overrides
# (§7.3) — the only way to grant it is by editing the config file — the test
# writes its own temp config.json files (opted-in and not) under a private
# XDG_CONFIG_HOME and points the server at them, rather than driving the server
# from KODI_* env like the other tests do.
#
# Preconditions (else the test SKIPs, automake exit 77):
#   - jq and curl on PATH
#   - the mcp-kodi binary built
#   - a reachable Kodi that answers JSONRPC.Ping with "pong"
#
# Target Kodi defaults to the local test instance; override via the environment:
#   KODI_HOST=127.0.0.1:8080  KODI_AUTH=user:pass  KODI_SCHEME=http
#
# Exit: 0 all assertions passed · 1 a failure · 77 skipped.

set -u

KODI_HOST=${KODI_HOST:-127.0.0.1:8080}
KODI_AUTH=${KODI_AUTH:-kodi:kodi}
KODI_SCHEME=${KODI_SCHEME:-http}

SKIP=77

skip () { echo "SKIP: $*"; exit $SKIP; }

# ---- dependencies ---------------------------------------------------------

command -v jq   >/dev/null 2>&1 || skip "jq not found"
command -v curl >/dev/null 2>&1 || skip "curl not found"

# Locate the mcp-kodi binary: the automake build tree first ($top_builddir is
# exported by `make check`), then fallbacks for running the script by hand.
find_binary () {
  for c in \
    "${top_builddir:-}/src/mcp-kodi" \
    "$(dirname "$0")/../src/mcp-kodi" \
    "./src/mcp-kodi" \
    "src/mcp-kodi"
  do
    if [ -n "$c" ] && [ -x "$c" ]; then printf '%s\n' "$c"; return 0; fi
  done
  return 1
}
MCP=$(find_binary) || skip "mcp-kodi binary not built"

# ---- talking to Kodi directly (for the liveness gate) ---------------------

kodi_rpc () { # method params-json  ->  raw JSON-RPC response
  curl -s -m 20 -u "$KODI_AUTH" -H 'Content-Type: application/json' \
    --data "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"$1\",\"params\":$2}" \
    "$KODI_SCHEME://$KODI_HOST/jsonrpc"
}

pong=$(kodi_rpc JSONRPC.Ping '{}' | jq -r '.result // empty' 2>/dev/null)
[ "$pong" = "pong" ] || skip "Kodi not reachable at $KODI_SCHEME://$KODI_HOST"

# ---- two server configs: one opted into rpc, one not ----------------------
#
# `allow_rpc` is hand-edit-only, so the test must materialise it in a config
# file. Both point at the same live Kodi; only the flag differs. A private
# XDG_CONFIG_HOME keeps the server off any real ~/.config/mcp-kodi/config.json.
WORK=$(mktemp -d) || skip "cannot mktemp"
trap 'rm -rf "$WORK"' EXIT
insecure=false
[ "$KODI_SCHEME" = https ] && insecure=true   # tolerate a self-signed test box

write_config () { # dir allow_rpc-bool
  mkdir -p "$1/mcp-kodi"
  jq -n --arg host "$KODI_HOST" --arg auth "$KODI_AUTH" --arg scheme "$KODI_SCHEME" \
        --argjson insecure "$insecure" --argjson allow "$2" \
    '{version:2, default:"local",
      instances:{local:{host:$host, auth:$auth, scheme:$scheme,
                        insecure:$insecure, allow_rpc:$allow}}}' \
    > "$1/mcp-kodi/config.json"
}
ON="$WORK/on";  write_config "$ON"  true
OFF="$WORK/off"; write_config "$OFF" false

# ---- talking to the server under test (MCP over stdio) --------------------

# Feed `initialize` + one `tools/call`, echo back the tool result object for
# request id 2. The server reads its config at startup from XDG_CONFIG_HOME, so
# $1 selects which config (opted-in or not) this call runs under. One invocation
# per call keeps every assertion isolated (the server exits on stdin EOF).
mcp_tool_cfg () { # xdg name arguments-json  ->  tool result object
  printf '%s\n%s\n' \
    '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2025-06-18","capabilities":{}}}' \
    "{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"tools/call\",\"params\":{\"name\":\"$2\",\"arguments\":$3}}" \
    | env -u KODI_HOST -u KODI_AUTH -u KODI_SCHEME XDG_CONFIG_HOME="$1" "$MCP" 2>/dev/null \
    | jq -c 'select(.id==2) | .result'
}

# The `tools/list` entry for one tool, under a given config.
mcp_tool_schema () { # xdg name  ->  the tool's inputSchema
  printf '%s\n%s\n' \
    '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2025-06-18","capabilities":{}}}' \
    '{"jsonrpc":"2.0","id":2,"method":"tools/list","params":{}}' \
    | env -u KODI_HOST -u KODI_AUTH -u KODI_SCHEME XDG_CONFIG_HOME="$1" "$MCP" 2>/dev/null \
    | jq -c "select(.id==2) | .result.tools[] | select(.name==\"$2\") | .inputSchema"
}

rpc_on  () { mcp_tool_cfg "$ON"  rpc "$1"; }   # arguments-json -> result object
rpc_off () { mcp_tool_cfg "$OFF" rpc "$1"; }   # arguments-json -> result object
res_err  () { printf '%s' "$1" | jq -r '.isError'; }            # "true" | "false"
res_body () { printf '%s' "$1" | jq -c '.content[0].text | fromjson'; }  # tool payload
res_text () { printf '%s' "$1" | jq -r '.content[0].text'; }    # raw text payload
g        () { printf '%s' "$1" | jq -r "$2"; } # body, filter -> scalar
j        () { printf '%s' "$1" | jq    "$2"; } # body, filter -> json/bool

# ---- assertions -----------------------------------------------------------

PASS=0
FAIL=0
ok () { PASS=$((PASS + 1)); printf '  ok   %s\n' "$1"; }
no () { FAIL=$((FAIL + 1)); printf '  FAIL %s\n' "$1"; shift; [ $# -gt 0 ] && printf '       %s\n' "$*"; return 0; }

eq () { # desc expected actual
  if [ "x$2" = "x$3" ]; then ok "$1"; else no "$1" "expected [$2] got [$3]"; fi
}
is_true () { # desc jq-bool-string
  if [ "x$2" = "xtrue" ]; then ok "$1"; else no "$1" "condition was [$2]"; fi
}
contains () { # desc haystack needle
  case "$2" in *"$3"*) ok "$1";; *) no "$1" "[$2] has no [$3]";; esac
}

echo "rpc functional test — Kodi at $KODI_SCHEME://$KODI_HOST, binary $MCP"

# ===========================================================================
# 1. The gate (§7.7): an instance that has NOT opted in refuses rpc, before any
#    Kodi call, with an error that points the user at allow_rpc.
# ===========================================================================
echo "-- gate: disabled instance"

b=$(rpc_off '{"method":"JSONRPC.Ping"}')
eq       "rpc on a non-opted-in instance is an error" true "$(res_err "$b")"
contains "disabled error names allow_rpc"  "$(g "$(res_body "$b")" '.error')" "allow_rpc"

# The escape hatch must not be grantable through the instances tool: a `set`
# trying to flip allow_rpc on is ignored, so rpc stays disabled.
b=$(mcp_tool_cfg "$OFF" instances '{"action":"set","key":"local","allow_rpc":true}')
eq "instances set is not an error" false "$(res_err "$b")"
got=$(res_body "$b" | jq -r '.instances[] | select(.key=="local") | .allow_rpc')
eq "instances set cannot enable allow_rpc" false "$got"
b=$(rpc_off '{"method":"JSONRPC.Ping"}')
eq "rpc still disabled after a set attempt" true "$(res_err "$b")"

# ===========================================================================
# 2. The hatch itself (§11.6.6), on an opted-in instance.
# ===========================================================================
echo "-- opted-in instance"

# 2a. Raw result, verbatim: JSONRPC.Ping → the bare string "pong" (not shaped
#     into an object), proving rpc returns Kodi's result untouched.
b=$(rpc_on '{"method":"JSONRPC.Ping"}')
eq "ping is not an error"            false   "$(res_err "$b")"
eq "ping returns the raw \"pong\""   '"pong"' "$(res_text "$b")"

# 2b. params passed straight through: ask for known Application properties and
#     read them back out of the raw result object.
b=$(rpc_on '{"method":"Application.GetProperties","params":{"properties":["volume","muted","version"]}}')
eq      "GetProperties is not an error"        false "$(res_err "$b")"
pb=$(res_body "$b")
is_true "raw result carries version.major"     "$(j "$pb" '(.version.major // 0) > 0')"
is_true "raw result carries a muted boolean"   "$(j "$pb" '(.muted | type) == "boolean"')"

# 2c. A Kodi-side error surfaces as a tool error (§3.4/§4.5), not a crash.
b=$(rpc_on '{"method":"NoSuch.Method"}')
eq       "unknown method -> tool error"  true "$(res_err "$b")"
contains "error mentions Kodi"           "$(g "$(res_body "$b")" '.error')" "Kodi error"

# ===========================================================================
# 3. Argument validation — clean tool errors, never a crash or a Kodi call.
# ===========================================================================
echo "-- argument validation"

b=$(rpc_on '{}')
eq       "missing method -> tool error"  true "$(res_err "$b")"
contains "missing-method error names method" "$(g "$(res_body "$b")" '.error')" "method"

b=$(rpc_on '{"method":"JSONRPC.Ping","params":[1,2]}')
eq       "non-object params -> tool error" true "$(res_err "$b")"
contains "params error names params"       "$(g "$(res_body "$b")" '.error')" "params"

# ===========================================================================
# 4. Discoverability: `instances get` reports allow_rpc, and the rpc schema
#    advertises which instances currently permit the hatch.
# ===========================================================================
echo "-- discoverability"

b=$(mcp_tool_cfg "$ON" instances '{"action":"get"}')
got=$(res_body "$b" | jq -r '.instances[] | select(.key=="local") | .allow_rpc')
eq "instances get reports allow_rpc:true" true "$got"

schema=$(mcp_tool_schema "$ON" rpc)
contains "rpc schema names the permitted instance" \
         "$(printf '%s' "$schema" | jq -r '.properties.method.description')" "local"

# ---- tally ----------------------------------------------------------------
echo "------------------------------------------------------------"
printf 'rpc functional test: %d passed, %d failed\n' "$PASS" "$FAIL"
[ "$FAIL" -eq 0 ] || exit 1
exit 0
