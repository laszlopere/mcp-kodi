#!/bin/sh
# Functional test for the `getplaylist` tool.
#
# Drives the real mcp-kodi binary over its MCP stdio transport against a live
# Kodi. `getplaylist` reads the current queue without changing it: the items of
# the active player's playlist — or of a playlist named by `type`
# (audio/video/picture), which always wins when provided — plus the `position`
# of the now-playing item, reported only when the playlist read is the active
# one. This test asserts the empty cases first (nothing playing, named idle
# playlists — an empty list, never an error), then starts real playback (one
# `playfile` plus one `queue` by library id), reads the grown queue back and
# checks every row against what was queued: files in order, the queued item's
# library id under its `<type>id` key, the playlist type, and position 0. The
# type-always-wins contract is exercised live: while that playback runs, the
# OTHER playlist type must still be readable — reporting its own (empty)
# content and NO position, since a cursor into someone else's playlist would
# be meaningless — while naming the active type explicitly must match the
# no-argument read, position included. Throughout, Kodi's own Playlist.GetItems
# confirms the tool changed nothing.
#
# Caller mistakes: an unknown `type` and an unconfigured instance must each
# return a tool error whose message names the mistake.
#
# Since real playback may be audible on a real device, the test reads the
# volume at startup, lowers it to 2% for the run, and restores the original on
# every exit (EXIT trap).
#
# Library-agnostic: it picks whatever movies or songs the library actually
# holds, so it passes against any *populated* library rather than assuming
# titles.
#
# Preconditions (else the test SKIPs, automake exit 77):
#   - jq and curl on PATH
#   - the mcp-kodi binary built
#   - a reachable Kodi that answers JSONRPC.Ping with "pong"
#   - at least two playable movies or songs in the library (else playback SKIPs)
#
# Target Kodi defaults to the local test instance; override via the environment:
#   KODI_HOST=127.0.0.1:8080  KODI_AUTH=user:pass  KODI_SCHEME=http
#
# Exit: 0 all assertions passed · 1 a failure · 77 skipped.

set -u

KODI_HOST=${KODI_HOST:-127.0.0.1:8080}
KODI_AUTH=${KODI_AUTH:-kodi:kodi}
KODI_SCHEME=${KODI_SCHEME:-http}
export KODI_HOST KODI_AUTH KODI_SCHEME

SKIP=77

skip () { echo "SKIP: $*"; exit $SKIP; }

# ---- dependencies ---------------------------------------------------------

command -v jq   >/dev/null 2>&1 || skip "jq not found"
command -v curl >/dev/null 2>&1 || skip "curl not found"

# Locate the mcp-kodi binary: the automake build tree first ($top_builddir is
# exported by `make check`), then fallbacks for running the script by hand.
find_binary () {
  for c in \
    "${top_builddir:-}/src/mcp-kodi" \
    "$(dirname "$0")/../src/mcp-kodi" \
    "./src/mcp-kodi" \
    "src/mcp-kodi"
  do
    if [ -n "$c" ] && [ -x "$c" ]; then printf '%s\n' "$c"; return 0; fi
  done
  return 1
}
MCP=$(find_binary) || skip "mcp-kodi binary not built"

# ---- talking to Kodi directly (for verification + the liveness gate) ------

kodi_rpc () { # method params-json  ->  raw JSON-RPC response
  curl -s -m 20 -u "$KODI_AUTH" -H 'Content-Type: application/json' \
    --data "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"$1\",\"params\":$2}" \
    "$KODI_SCHEME://$KODI_HOST/jsonrpc"
}

pong=$(kodi_rpc JSONRPC.Ping '{}' | jq -r '.result // empty' 2>/dev/null)
[ "$pong" = "pong" ] || skip "Kodi not reachable at $KODI_SCHEME://$KODI_HOST"

# ---- volume guard ----------------------------------------------------------
# The test starts real playback on a possibly real device, so remember the
# current volume, run quietly at 2%, and restore the original on every exit.
vol0=$(kodi_rpc Application.GetProperties '{"properties":["volume"]}' \
        | jq -r '.result.volume // empty')
restore_volume () {
  [ -n "$vol0" ] && kodi_rpc Application.SetVolume "{\"volume\":$vol0}" >/dev/null 2>&1
}
trap restore_volume EXIT
[ -n "$vol0" ] && kodi_rpc Application.SetVolume '{"volume":2}' >/dev/null 2>&1

# ---- talking to the server under test (MCP over stdio) --------------------

# Feed `initialize` + one `tools/call`, echo back the tool result object for
# request id 2 (`{ content:[{type,text}], isError }`). The server reads
# newline-delimited JSON and exits on EOF, so one invocation per call keeps
# every assertion isolated.
mcp_tool () { # name arguments-json  ->  tool result object
  printf '%s\n%s\n' \
    '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2025-06-18","capabilities":{}}}' \
    "{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"tools/call\",\"params\":{\"name\":\"$1\",\"arguments\":$2}}" \
    | "$MCP" 2>/dev/null \
    | jq -c 'select(.id==2) | .result'
}

getpl    () { mcp_tool getplaylist "$1"; }     # arguments-json -> result object
queue    () { mcp_tool queue       "$1"; }
playfile () { mcp_tool playfile    "$1"; }
search   () { mcp_tool search      "$1"; }
stop_t   () { mcp_tool stop        "$1"; }
res_err  () { printf '%s' "$1" | jq -r '.isError'; }            # "true" | "false"
res_body () { printf '%s' "$1" | jq -c '.content[0].text | fromjson'; }  # tool payload
jargs    () { jq -cn "$@"; }                   # build an arguments object safely
g        () { printf '%s' "$1" | jq -r "$2"; } # body, filter -> scalar
j        () { printf '%s' "$1" | jq    "$2"; } # body, filter -> json/bool

# ---- assertions -----------------------------------------------------------

PASS=0
FAIL=0
ok () { PASS=$((PASS + 1)); printf '  ok   %s\n' "$1"; }
no () { FAIL=$((FAIL + 1)); printf '  FAIL %s\n' "$1"; shift; [ $# -gt 0 ] && printf '       %s\n' "$*"; return 0; }

eq () { # desc expected actual
  if [ "x$2" = "x$3" ]; then ok "$1"; else no "$1" "expected [$2] got [$3]"; fi
}
is_true () { # desc jq-bool-string
  if [ "x$2" = "xtrue" ]; then ok "$1"; else no "$1" "condition was [$2]"; fi
}
contains () { # desc needle haystack
  case "$3" in
    *"$2"*) ok "$1";;
    *)      no "$1" "wanted [$2] in [$3]";;
  esac
}

echo "getplaylist functional test — Kodi at $KODI_SCHEME://$KODI_HOST, binary $MCP"

# ---- the volume guard took hold: Kodi reports the quiet test level ---------
echo "-- volume guard (was: ${vol0:-unknown}%)"
eq "volume lowered to 2% for the test run" 2 \
   "$(kodi_rpc Application.GetProperties '{"properties":["volume"]}' \
       | jq -r '.result.volume')"

# ===========================================================================
# 1. Caller mistakes: each is a clean tool error (isError:true) whose message
#    names what was wrong.
# ===========================================================================
echo "-- errors / edges"

b=$(getpl '{"type":"slideshow"}')
eq "unknown type -> tool error" true "$(res_err "$b")"
contains "unknown type -> message names the accepted kinds" \
         "audio/video/picture" "$(g "$(res_body "$b")" '.error')"

# An unconfigured instance is a communication failure: the error carries the
# no_instance category and a setup hint, so the AI can help fix the config.
b=$(getpl '{"instance":"no-such-box"}')
eq "unknown instance -> tool error" true "$(res_err "$b")"
eq "unknown instance -> category no_instance" no_instance \
   "$(g "$(res_body "$b")" '.category')"
is_true "unknown instance -> carries a setup hint" \
        "$(j "$(res_body "$b")" 'has("hint") and (.hint|length>0)')"

# ===========================================================================
# 2. Empty cases: stop any active player and clear every playlist, then the
#    no-argument read (nothing playing) and each named idle playlist must all
#    come back as an empty list — never an error.
# ===========================================================================
echo "-- empty cases"

active=$(kodi_rpc Player.GetActivePlayers '{}' | jq -r '.result[0].playerid // empty')
[ -n "$active" ] && kodi_rpc Player.Stop "{\"playerid\":$active}" >/dev/null 2>&1
sleep 1
for plid in 0 1 2; do
  kodi_rpc Playlist.Clear "{\"playlistid\":$plid}" >/dev/null 2>&1
done

b=$(getpl '{}')
eq "nothing playing, no type -> not an error" false "$(res_err "$b")"
body=$(res_body "$b")
eq "nothing playing -> total 0"        0 "$(g "$body" '.total')"
eq "nothing playing -> items empty"    0 "$(g "$body" '.items | length')"
eq "nothing playing -> no position"    false "$(j "$body" 'has("position")')"

for t in audio video picture; do
  b=$(getpl "{\"type\":\"$t\"}")
  eq "idle $t playlist -> not an error" false "$(res_err "$b")"
  body=$(res_body "$b")
  eq "idle $t playlist -> reports its type" "$t" "$(g "$body" '.type')"
  eq "idle $t playlist -> empty list"       0    "$(g "$body" '.items | length')"
done

# ===========================================================================
# 3. Discover TWO playable leaves of the same type via `search`. Prefer
#    movies; fall back to songs so the test runs against an audio-only
#    library too.
# ===========================================================================
kind=""
b=$(res_body "$(search '{"type":"movie","limit":2}')")
if [ "$(j "$b" '.returned >= 2')" = true ]; then
  kind=movie idkey=movieid pltype=video
else
  # Need an artist to drill music to song leaves; pick the first one Kodi lists.
  artist=$(kodi_rpc AudioLibrary.GetArtists '{"limits":{"start":0,"end":1}}' \
            | jq -r '.result.artists[0].artist // empty')
  if [ -n "$artist" ]; then
    b=$(res_body "$(search "$(jargs --arg a "$artist" '{type:"music",artist:$a,limit:2}')")")
    if [ "$(j "$b" '.returned >= 2')" = true ]; then
      kind=song idkey=songid pltype=audio
    fi
  fi
fi

if [ -z "$kind" ]; then
  echo "   (library holds fewer than two movies or songs — playback assertions skipped)"
  echo "------------------------------------------------------------"
  printf 'getplaylist functional test: %d passed, %d failed\n' "$PASS" "$FAIL"
  [ "$FAIL" -eq 0 ] || exit 1
  exit 0
fi

file1=$(g "$b" '.rows[0].file')
file2=$(g "$b" '.rows[1].file')
id2=$(g "$b" ".rows[1].$idkey")

# ===========================================================================
# 4. Read a real queue back: play the first leaf (Player.Open auto-creates
#    the one-item playlist), queue the second by library id, then the no-argument
#    read must report both rows in order, the playlist's type, position 0,
#    and the queued row's library id under its `<type>id` key — agreeing with
#    Kodi's own Playlist.GetItems.
# ===========================================================================
echo "-- reading the active queue ($kind)"
echo "   (playing: $file1)"
echo "   (queued:  $file2)"

b=$(playfile "$(jargs --arg f "$file1" '{file:$f}')")
eq "playfile starts the first leaf" false "$(res_err "$b")"
b=$(queue "$(jargs --arg t "$kind" --argjson i "$id2" '{type:$t,id:$i}')")
eq "queue appends the second leaf" false "$(res_err "$b")"

b=$(getpl '{}')
eq "reading the active queue is not an error" false "$(res_err "$b")"
body=$(res_body "$b")
eq "queue type is the playing playlist's" "$pltype" "$(g "$body" '.type')"
eq "queue holds both items"               2         "$(g "$body" '.total')"
eq "playback sits at position 0"          0         "$(g "$body" '.position')"
eq "first row is the playing file"        "$file1"  "$(g "$body" '.items[0].file')"
eq "second row is the queued file"        "$file2"  "$(g "$body" '.items[1].file')"
eq "the queued row carries its library id under $idkey" \
   "$id2" "$(g "$body" ".items[1].$idkey")"
is_true "every row names its media type" \
        "$(j "$body" '[.items[].type] | all(length > 0)')"

# Kodi independently agrees the read-only tool changed nothing.
plid=$(kodi_rpc Player.GetActivePlayers '{}' | jq -r '.result[0].playerid')
plid=$(kodi_rpc Player.GetProperties \
        "{\"playerid\":$plid,\"properties\":[\"playlistid\"]}" \
        | jq -r '.result.playlistid')
eq "Kodi still holds both items (read-only confirmed)" 2 \
   "$(kodi_rpc Playlist.GetItems "{\"playlistid\":$plid}" \
       | jq -r '.result.items | length')"

# ===========================================================================
# 5. type always wins: while this playback runs, the OTHER playlist
#    type must still be readable — its own (empty) content, its own type, and
#    NO position, since the playlist read is not the active one. Naming the
#    active type explicitly must match the no-argument read, position included.
# ===========================================================================
[ "$pltype" = video ] && other=audio || other=video
echo "-- type always wins (reading $other while $pltype plays)"

b=$(getpl "{\"type\":\"$other\"}")
eq "reading the inactive $other playlist is not an error" false "$(res_err "$b")"
body=$(res_body "$b")
eq "the inactive read reports its own type" "$other" "$(g "$body" '.type')"
eq "the inactive playlist is empty"         0        "$(g "$body" '.total')"
eq "no position outside the active playlist" false \
   "$(j "$body" 'has("position")')"

b=$(getpl "{\"type\":\"$pltype\"}")
body=$(res_body "$b")
eq "naming the active type reads the same queue" 2 "$(g "$body" '.total')"
eq "naming the active type keeps the position"   0 "$(g "$body" '.position')"

# ===========================================================================
# 6. Cleanup via the `stop` tool (it also clears the playlist it stopped):
#    the queue read afterwards must be empty again. The volume
#    guard's EXIT trap then restores the volume.
# ===========================================================================
echo "-- after stop"
b=$(stop_t '{}')
eq "stop is not an error" false "$(res_err "$b")"
b=$(getpl "{\"type\":\"$pltype\"}")
eq "the stopped queue reads back empty" 0 "$(g "$(res_body "$b")" '.total')"

# ---- tally ----------------------------------------------------------------
echo "------------------------------------------------------------"
printf 'getplaylist functional test: %d passed, %d failed\n' "$PASS" "$FAIL"
[ "$FAIL" -eq 0 ] || exit 1
exit 0
