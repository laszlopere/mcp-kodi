#!/bin/sh
# Functional test for the `playfile` tool.
#
# Drives the real mcp-kodi binary over its MCP stdio transport against a live
# Kodi. `playfile` opens one file by path with Player.Open and returns the
# player_state() snapshot, so this test discovers a real playable `file` from
# the target library (via `search`, the tool whose result feeds playfile), plays
# it, and asserts the now-playing snapshot reflects that file. It then restores
# the player to its prior state so it leaves no media running.
#
# Library-agnostic: it picks whatever movie or song the library actually holds,
# so it passes against any *populated* library rather than assuming titles.
#
# Preconditions (else the test SKIPs, automake exit 77):
#   - jq and curl on PATH
#   - the mcp-kodi binary built
#   - a reachable Kodi that answers JSONRPC.Ping with "pong"
#   - at least one playable movie or song in the library (else playback SKIPs)
#
# Target Kodi defaults to the local test instance; override via the environment:
#   KODI_HOST=127.0.0.1:8080  KODI_AUTH=user:pass  KODI_SCHEME=http
#
# Exit: 0 all assertions passed · 1 a failure · 77 skipped.

set -u

KODI_HOST=${KODI_HOST:-127.0.0.1:8080}
KODI_AUTH=${KODI_AUTH:-kodi:kodi}
KODI_SCHEME=${KODI_SCHEME:-http}
export KODI_HOST KODI_AUTH KODI_SCHEME

SKIP=77

skip () { echo "SKIP: $*"; exit $SKIP; }

# ---- dependencies ---------------------------------------------------------

command -v jq   >/dev/null 2>&1 || skip "jq not found"
command -v curl >/dev/null 2>&1 || skip "curl not found"

# Locate the mcp-kodi binary: the automake build tree first ($top_builddir is
# exported by `make check`), then fallbacks for running the script by hand.
find_binary () {
  for c in \
    "${top_builddir:-}/src/mcp-kodi" \
    "$(dirname "$0")/../src/mcp-kodi" \
    "./src/mcp-kodi" \
    "src/mcp-kodi"
  do
    if [ -n "$c" ] && [ -x "$c" ]; then printf '%s\n' "$c"; return 0; fi
  done
  return 1
}
MCP=$(find_binary) || skip "mcp-kodi binary not built"

# ---- talking to Kodi directly (for discovery + the liveness gate) ---------

kodi_rpc () { # method params-json  ->  raw JSON-RPC response
  curl -s -m 20 -u "$KODI_AUTH" -H 'Content-Type: application/json' \
    --data "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"$1\",\"params\":$2}" \
    "$KODI_SCHEME://$KODI_HOST/jsonrpc"
}

pong=$(kodi_rpc JSONRPC.Ping '{}' | jq -r '.result // empty' 2>/dev/null)
[ "$pong" = "pong" ] || skip "Kodi not reachable at $KODI_SCHEME://$KODI_HOST"

# ---- talking to the server under test (MCP over stdio) --------------------

# Feed `initialize` + one `tools/call`, echo back the tool result object for
# request id 2 (`{ content:[{type,text}], isError }`). The server reads
# newline-delimited JSON and exits on EOF, so one invocation per call keeps
# every assertion isolated.
mcp_tool () { # name arguments-json  ->  tool result object
  printf '%s\n%s\n' \
    '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2025-06-18","capabilities":{}}}' \
    "{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"tools/call\",\"params\":{\"name\":\"$1\",\"arguments\":$2}}" \
    | "$MCP" 2>/dev/null \
    | jq -c 'select(.id==2) | .result'
}

playfile () { mcp_tool playfile "$1"; }        # arguments-json -> result object
search   () { mcp_tool search   "$1"; }        # arguments-json -> result object
res_err  () { printf '%s' "$1" | jq -r '.isError'; }            # "true" | "false"
res_body () { printf '%s' "$1" | jq -c '.content[0].text | fromjson'; }  # tool payload
jargs    () { jq -cn "$@"; }                   # build an arguments object safely
g        () { printf '%s' "$1" | jq -r "$2"; } # body, filter -> scalar
j        () { printf '%s' "$1" | jq    "$2"; } # body, filter -> json/bool

# ---- assertions -----------------------------------------------------------

PASS=0
FAIL=0
ok () { PASS=$((PASS + 1)); printf '  ok   %s\n' "$1"; }
no () { FAIL=$((FAIL + 1)); printf '  FAIL %s\n' "$1"; shift; [ $# -gt 0 ] && printf '       %s\n' "$*"; return 0; }

eq () { # desc expected actual
  if [ "x$2" = "x$3" ]; then ok "$1"; else no "$1" "expected [$2] got [$3]"; fi
}
is_true () { # desc jq-bool-string
  if [ "x$2" = "xtrue" ]; then ok "$1"; else no "$1" "condition was [$2]"; fi
}

echo "playfile functional test — Kodi at $KODI_SCHEME://$KODI_HOST, binary $MCP"

# ===========================================================================
# 1. Error path first (no library needed): a bad request is a clean tool
#    error (isError:true), never a crash.
# ===========================================================================
echo "-- errors / edges"

b=$(playfile '{}')
eq "missing file -> tool error" true "$(res_err "$b")"
case "$(g "$(res_body "$b")" '.error')" in
  *file*) ok "missing-file error names \"file\"";;
  *)      no "missing-file error names \"file\"";;
esac

b=$(playfile '{"file":""}')
eq "empty file -> tool error" true "$(res_err "$b")"

# Missing media (TODO 11.12), the outside-sources flavour: a nonexistent path
# outside the configured media sources cannot be verified by listing (Kodi
# refuses to browse out there), so it travels on to Player.Open where Kodi
# disk-checks it itself — and that refusal must come back named and explained,
# not as a bare "Invalid params". (On a box whose sources happen to cover the
# path, the pre-check catches it instead — "missing from disk".)
b=$(playfile '{"file":"/tmp/mcp-kodi-no-such-file-on-disk.mp3"}')
eq "missing non-source file -> tool error" true "$(res_err "$b")"
case "$(g "$(res_body "$b")" '.error')" in
  *"refused to open"*|*"missing from disk"*)
     ok "missing-file error names the cause";;
  *) no "missing-file error names the cause" \
        "$(g "$(res_body "$b")" '.error')";;
esac
case "$(g "$(res_body "$b")" '.error')" in
  *"mcp-kodi-no-such-file-on-disk.mp3"*)
     ok "missing-file error names the file";;
  *) no "missing-file error names the file";;
esac

# ===========================================================================
# 2. Discover a real playable file via `search` — the tool whose result row's
#    `file` is exactly the playfile input. Prefer a movie; fall back to
#    a song so the test runs against an audio-only library too.
# ===========================================================================
file=""
kind=""
b=$(res_body "$(search '{"type":"movie","limit":1}')")
if [ "$(j "$b" '.returned >= 1')" = true ]; then
  file=$(g "$b" '.rows[0].file'); kind=movie
else
  # Need an artist to drill music to a song leaf; pick the first one Kodi lists.
  artist=$(kodi_rpc AudioLibrary.GetArtists '{"limits":{"start":0,"end":1}}' \
            | jq -r '.result.artists[0].artist // empty')
  if [ -n "$artist" ]; then
    b=$(res_body "$(search "$(jargs --arg a "$artist" '{type:"music",artist:$a,limit:1}')")")
    if [ "$(j "$b" '.returned >= 1')" = true ]; then
      file=$(g "$b" '.rows[0].file'); kind=song
    fi
  fi
fi

if [ -z "$file" ]; then
  echo "   (no playable movie or song in library — playback assertions skipped)"
  echo "------------------------------------------------------------"
  printf 'playfile functional test: %d passed, %d failed\n' "$PASS" "$FAIL"
  [ "$FAIL" -eq 0 ] || exit 1
  exit 0
fi

# ===========================================================================
# 2b. Missing media under a real source (TODO 11.12): fabricate stale-library
#     paths from the discovered file's own folder — that folder is inside a
#     configured source, so the disk pre-check is authoritative there. Both
#     verdicts, neither touching the player:
#       - the folder lists fine but holds no such file
#       - the folder itself is gone (cannot be listed despite the source)
# ===========================================================================
echo "-- missing media (stale library paths)"
dir=${file%/*}
active_before=$(kodi_rpc Player.GetActivePlayers '{}' | jq -r '.result | length')

b=$(playfile "$(jargs --arg f "$dir/mcp-kodi-no-such-file.mp3" '{file:$f}')")
eq "missing file in a real source dir -> tool error" true "$(res_err "$b")"
case "$(g "$(res_body "$b")" '.error')" in
  *"missing from disk"*) ok "stale-entry error says missing from disk";;
  *)                     no "stale-entry error says missing from disk" \
                            "$(g "$(res_body "$b")" '.error')";;
esac

b=$(playfile "$(jargs --arg f "$dir/mcp-kodi-no-such-subdir/x.mp3" '{file:$f}')")
eq "file in a vanished source subdir -> tool error" true "$(res_err "$b")"
case "$(g "$(res_body "$b")" '.error')" in
  *"cannot be listed"*) ok "vanished-folder error explains the folder is gone";;
  *)                    no "vanished-folder error explains the folder is gone" \
                           "$(g "$(res_body "$b")" '.error')";;
esac

# Neither refused request may have touched the player (started or stopped one).
active=$(kodi_rpc Player.GetActivePlayers '{}' | jq -r '.result | length')
eq "refused plays left the player untouched" "${active_before:-0}" "${active:-0}"

# Remember what was playing so the test restores it rather than leaving media
# running on a real device.
prev=$(kodi_rpc Player.GetActivePlayers '{}' | jq -r '.result[0].playerid // empty')

# ===========================================================================
# 3. Play the discovered file and assert the now-playing snapshot.
# ===========================================================================
echo "-- playback ($kind)"
echo "   (file: $file)"

b=$(playfile "$(jargs --arg f "$file" '{file:$f}')")
eq "playfile is not an error" false "$(res_err "$b")"
pb=$(res_body "$b")

is_true "snapshot reports a state field"      "$(j "$pb" 'has("state")')"
eq      "state is playing"                     playing "$(g "$pb" '.state')"
eq      "snapshot echoes the played file"      "$file" "$(g "$pb" '.file')"
is_true "snapshot carries a non-empty totaltime" \
        "$(j "$pb" '(.totaltime // {}) | (.hours+.minutes+.seconds+.milliseconds) > 0')"
if [ "$kind" = movie ]; then
  eq    "video file selects the video player"  video "$(g "$pb" '.type')"
fi
# Library enrichment: a scanned file gets a human label/title back.
is_true "snapshot carries a label"            "$(j "$pb" 'has("label") and (.label|length>0)')"

# Kodi independently agrees a player is now active.
active=$(kodi_rpc Player.GetActivePlayers '{}' | jq -r '.result | length')
is_true "Kodi confirms a player is active"     "$([ "${active:-0}" -ge 1 ] && echo true || echo false)"

# ===========================================================================
# 4. Cleanup — stop our playback. (We do not resume the prior item; restoring
#    exact position is out of scope. Leaving the player stopped is the safe
#    neutral state.)
# ===========================================================================
now=$(kodi_rpc Player.GetActivePlayers '{}' | jq -r '.result[0].playerid // empty')
[ -n "$now" ] && kodi_rpc Player.Stop "{\"playerid\":$now}" >/dev/null 2>&1
[ -n "$prev" ] && echo "   (note: a player was active before the test; left stopped)"

# ---- tally ----------------------------------------------------------------
echo "------------------------------------------------------------"
printf 'playfile functional test: %d passed, %d failed\n' "$PASS" "$FAIL"
[ "$FAIL" -eq 0 ] || exit 1
exit 0
